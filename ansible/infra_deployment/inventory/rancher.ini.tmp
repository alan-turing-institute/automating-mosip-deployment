[deployment]
deployment-node ansible_connection=local

[physical_vms]
# Physical VMs where nodes are running
vm1 ansible_host=10.100.3.
vm2 ansible_host=10.100.3.
vm3 ansible_host=10.100.3.
vm4 ansible_host=10.100.3.
vm5 ansible_host=10.100.3.
vm6 ansible_host=10.100.3.

# RKE2 cluster groups
# Default colocated topology: all 6 nodes run rke2-server (shared control plane + workloads).
# vm1 = primary CP; vm2–vm6 = HA CP servers that also schedule pods.
# Leave [rke2_agents] empty unless you add dedicated worker-only nodes later.
[control_plane_primary]
vm1 ansible_host=10.100.3.

[control_plane_subsequent]
vm2 ansible_host=10.100.3.
vm3 ansible_host=10.100.3.
vm4 ansible_host=10.100.3.
vm5 ansible_host=10.100.3.
vm6 ansible_host=10.100.3.

[rke2_agents]
# Intentionally empty in default colocated layout (no rke2-agent-only nodes)

# Optional dedicated etcd nodes (leave empty for embedded etcd on servers)
[rke2_etcd]

[rke2_cluster:children]
control_plane_primary
control_plane_subsequent
rke2_agents

# Nodes that run MOSIP workloads (nginx upstream / NodePort targets)
[worker_nodes]
vm1
vm2
vm3
vm4
vm5
vm6

[mosip_obs]
# Single node Rancher OBS cluster
obs-node-1 ansible_host=10.100.3.

[nginx]
# Add your nginx nodes here
nginx-node-1 ansible_host=10.100.1.

[nginx_obs]
# Add your OBS nginx nodes here
nginx-obs-node-1 ansible_host=10.100.3.

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3
ansible_host_key_checking=False

[mosip_obs:vars]
node_role=obs
