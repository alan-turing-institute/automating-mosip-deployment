---
# Platform component versions (Ansible + deployment node)
# Copy to group_vars/platform_versions.yml alongside group_vars/all.yml
#
# Change ONE line to move stacks: platform_version_profile
# Must match terraform/platform_versions.tfvars → platform_version_profile

platform_version_profile: "k8s_1_28" # k8s_1_28 (tested) | k8s_1_35 (future)

version_profiles:
  k8s_1_28:
    rke2_version: "v1.28.8+rke2r1"
    kubectl_client_version: "v1.28.15"
    helm_client_version: "v3.16.4"
    istio_version: "1.22.0"
  k8s_1_35:
    rke2_version: "v1.35.5+rke2r2"
    kubectl_client_version: "v1.35.2"
    helm_client_version: "v3.18.4"
    istio_version: "1.30.0"

# Active pins (from profile; override individual keys below if needed for a one-off)
rke2_version: "{{ version_profiles[platform_version_profile].rke2_version }}"
kubectl_client_version: "{{ version_profiles[platform_version_profile].kubectl_client_version }}"
helm_client_version: "{{ version_profiles[platform_version_profile].helm_client_version }}"
istio_version: "{{ version_profiles[platform_version_profile].istio_version }}"

# Optional one-off overrides (uncomment to bypass profile for a single component):
# rke2_version: "v1.28.8+rke2r1"
# kubectl_client_version: "v1.28.15"
# helm_client_version: "v3.16.4"
# istio_version: "1.22.0"
