# AWS provider region
#aws_region = "ap-south-1"
aws_region = "eu-west-1"

# REQUIRED: AWS EC2 key pair name used by ALL VMs created by this module.
# This must exactly match an existing key pair in aws_region.
# Do NOT leave empty and do NOT use placeholder text.
# Example: ssh_key_name = "mosip-dev-keypair"
ssh_key_name = ""

# Core metadata
environment  = "dev"
project_name = "mosip"

# Network
network_name       = "mosip-boxes"
network_cidr       = "10.0.0.0/16"
public_subnets     = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnets    = ["10.0.3.0/24", "10.0.4.0/24"]
wireguard_cidr     = "10.13.13.0/24" # WireGuard client tunnel subnet (must match wg Interface Address range)
#availability_zones = ["ap-south-1a", "ap-south-1b"]
availability_zones = ["eu-west-1a", "eu-west-1b"]

# Networking options
enable_nat_gateway   = true
single_nat_gateway   = true
enable_dns_hostnames = true
enable_dns_support   = true

# Jumpserver
jumpserver_name          = "wg-bastion"
jumpserver_instance_type = "t3a.2xlarge"
#jumpserver_ami_id        = "ami-0ad21ae1d0696ad58" #24.04
#jumpserver_ami_id        = "ami-05e2a86d8dfbc265b" #22.04
jumpserver_ami_id        = "ami-0bfd171be0640d169" #22.04 Ireland
create_jumpserver_eip    = true

# Ansible-target compute nodes
#node_ami_id             = "ami-0ad21ae1d0696ad58" #24.04
#node_ami_id        = "ami-05e2a86d8dfbc265b" #22.04
node_ami_id        = "ami-0bfd171be0640d169" #22.04 Ireland
k8s_instance_type       = "t3a.2xlarge"
nginx_instance_type     = "t3a.2xlarge"
obs_instance_type       = "t3a.2xlarge"
nginx_obs_instance_type = "t3a.2xlarge"
physical_vm_count       = 6
control_plane_count     = 3
etcd_count              = 3
worker_count            = 6

# Optional Route53 automation
enable_route53_records = false
cluster_env_domain     = "warwick-1.turing-mosip.net"
# cluster_env_domain is the FULL deployment domain (can include subdomain), used in record names.
# Examples:
# - turing-mosip.net
# - warwick-1.turing-mosip.net

# IMPORTANT: choose exactly ONE option below when enable_route53_records=true.
# Option A (explicit ID): Route53 hosted zone ID where records are created.
route53_zone_id        = ""
# Option B (auto-resolve ID): hosted zone DNS name where records are created (usually parent zone/TLD in your account).
# Example for cluster_env_domain=warwick-1.turing-mosip.net: route53_zone_name="turing-mosip.net"
route53_zone_name      = ""
# NOTE: Values below must be LABELS only (without cluster_env_domain suffix).
# Example: use "signup", not "signup.warwick-1.turing-mosip.net".
subdomain_obs_a_records = ["rancher", "rancher-keycloak"]
subdomain_public        = ["prereg", "resident", "idp", "admin"]
subdomain_internal      = ["activemq", "kibana", "regclient", "object-store", "kafka", "iam", "postgres", "pmp", "onboarder", "smtp", "minio", "esignet", "healthservices", "signup"]
enable_root_domain_record = true
root_domain_record_type   = "A"

# Optional certbot Route53 IAM/profile attachment on nginx node
enable_certbot_iam_profile = false
